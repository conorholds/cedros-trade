[package]
name = "cedros-trade"
version = "0.1.0"
edition = "2021"
rust-version = "1.75"
license = "MIT"
description = "Solana trading infrastructure — multi-provider swap routing, token registry, price aggregation"

[[bin]]
name = "cedros-trade"
path = "src/main.rs"

[lib]
name = "cedros_trade"
path = "src/lib.rs"

[dependencies]
axum = { version = "0.7", features = ["macros", "ws"] }
tokio = { version = "1", features = ["full"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
reqwest = { version = "0.12", features = ["json"] }
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter", "json"] }
toml = "0.8"
clap = { version = "4", features = ["derive"] }
tower-http = { version = "0.5", features = ["cors", "trace"] }
thiserror = "1"
async-trait = "0.1"
bs58 = "0.5"
base64 = "0.22"
chrono = { version = "0.4", features = ["serde"] }
dashmap = "6"
tower = "0.4"
futures = "0.3"
anyhow = "1"
sqlx = { version = "0.8", features = ["runtime-tokio", "tls-native-tls", "postgres", "chrono"] }
uuid = { version = "1", features = ["v4"] }
tokio-stream = "0.1"
sha2 = "0.10"
curve25519-dalek = "4"

[dev-dependencies]
axum-test = "15"
wiremock = "0.6"
tokio = { version = "1", features = ["full", "test-util"] }
