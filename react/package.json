{
  "name": "@cedros/trade-react",
  "version": "0.1.0",
  "description": "Solana trading UI components — swap, transfer, trading, portfolio",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "style": "dist/trade-react.css",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./admin-only": {
      "import": "./dist/admin-only.js",
      "require": "./dist/admin-only.cjs",
      "types": "./dist/admin-only.d.ts"
    },
    "./style.css": "./dist/trade-react.css"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@cedros/login-react": {
      "optional": true
    },
    "@solana/wallet-adapter-react": {
      "optional": true
    }
  },
  "dependencies": {
    "lightweight-charts": "^4.2.0"
  },
  "license": "MIT"
}
